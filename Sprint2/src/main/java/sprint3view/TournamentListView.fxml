<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sprint3view.TournamentListController">
   <center>
      <VBox prefHeight="374.0" prefWidth="437.0" BorderPane.alignment="CENTER">
         <children>
            <HBox prefHeight="155.0" prefWidth="600.0">
               <children>
                  <Label alignment="CENTER" prefHeight="69.0" prefWidth="326.0" text="Please select a tournament:">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <ButtonBar prefHeight="155.0" prefWidth="166.0">
                    <buttons>
                        <VBox alignment="CENTER" prefHeight="151.0" prefWidth="224.0">
                           <children>
                              <Button fx:id="AllTournamentsButton" mnemonicParsing="false" onAction="#onClickAllTournamentsFilter" prefHeight="28.0" prefWidth="152.0" text="All Tournaments" />
                              <Region prefHeight="18.0" prefWidth="207.0" />
                            <Button fx:id="OpenRegistrationButton" mnemonicParsing="false" onAction="#onClickOpenTournamentsFilter" prefHeight="15.0" prefWidth="145.0" text="Open Registration" />
                              <Region prefHeight="20.0" prefWidth="100.0" />
                              <Button fx:id="ActiveTournamentsButton" mnemonicParsing="false" onAction="#onClickActiveTournamentsFilter" prefHeight="20.0" prefWidth="139.0" text="Active Tournaments" />
                           </children>
                        </VBox>
                    </buttons>
                  </ButtonBar>
                  <Region prefHeight="155.0" prefWidth="91.0" />
                  <Button fx:id="spectateButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onClickView" prefHeight="30.0" prefWidth="106.0" text="Spectate" textAlignment="CENTER" />
                  <Region prefHeight="151.0" prefWidth="39.0" />
               </children>
            </HBox>
            <ScrollPane prefHeight="200.0" prefWidth="600.0">
               <content>
                  <ListView fx:id="tournamentListView" prefHeight="200.0" prefWidth="586.0" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
   <top>
      <Button fx:id="connectToNewServerButton" alignment="CENTER" contentDisplay="TOP" mnemonicParsing="false" onAction="#onClickBack" text="Connect to new server" textAlignment="CENTER" BorderPane.alignment="TOP_LEFT" />
   </top>
</BorderPane>
