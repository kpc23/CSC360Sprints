<VBox fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sprint3view.ConnectToServerController">
   <children>
      <Label alignment="CENTER" prefHeight="92.0" prefWidth="526.0" text="Connect to a Server">
