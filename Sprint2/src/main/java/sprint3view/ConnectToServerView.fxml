            <TextField fx:id="IPTextField" prefHeight="26.0" prefWidth="199.0" promptText="Enter IP" GridPane.columnIndex="1" />
            <TextField fx:id="PortNumberTextField" promptText="Enter port number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
         </children>
      </GridPane>
   </children>
</VBox>
